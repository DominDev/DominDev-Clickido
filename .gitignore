.yarn-integrity
pnpm-lock.yaml

# === Build / Generated ===
dist/
build/

# === Environment & Secrets ===
.env
.env.local
.env.*.local
*.pem
*.key

# === Logs ===
logs/
*.log

# === Temporary Files ===
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# === Cache ===
.cache/
*.cache
.vite/
.eslintcache
.stylelintcache

# === Project Internal Docs ===
_docs/

